<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_sync_customers" model="ir.cron">
            <field name="name">Sync Customers from WebApp</field>
            <field name="model_id" ref="webapp_odoo_sync.model_sync_config"/>
            <field name="state">code</field>
            <field name="code">model.search([], limit=1).action_sync_customers()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_sync_products" model="ir.cron">
            <field name="name">Sync Products from WebApp</field>
            <field name="model_id" ref="webapp_odoo_sync.model_sync_config"/>
            <field name="state">code</field>
            <field name="code">model.search([], limit=1).action_sync_products()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_sync_orders" model="ir.cron">
            <field name="name">Sync Orders from WebApp</field>
            <field name="model_id" ref="webapp_odoo_sync.model_sync_config"/>
            <field name="state">code</field>
            <field name="code">model.search([], limit=1).action_sync_orders()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
